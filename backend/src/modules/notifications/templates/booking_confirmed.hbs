<html>
  <head>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 5px;
      }
      .header {
        font-size: 24px;
        color: #2c3e50;
      }
      .footer {
        margin-top: 20px;
        font-size: 12px;
        color: #777;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>Booking Confirmed!</div>
      <p>Hello {{name}},</p>
      <p>Your booking
        <strong>{{bookingNumber}}</strong>
        for
        <strong>{{tourTitle}}</strong>
        has been confirmed.</p>
      <p>Date: {{startDate}}</p>
      <p>Total Amount Paid: {{amount}}</p>
      <p>We look forward to seeing you!</p>
      <div class='footer'>
        <p>TrekStories Team</p>
      </div>
    </div>
  </body>
</html>